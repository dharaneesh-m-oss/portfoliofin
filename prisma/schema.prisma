generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id          String   @id @default(cuid())
  title       String
  status      String
  hardware    String?
  domain      String
  impact      String
  tags        String   // Stored as JSON string
  description String
  details     String   // Stored as JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  title       String
  org         String
  date        String
  desc        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Teammate {
  id          String   @id @default(cuid())
  name        String
  role        String
  bio         String
  image       String?
  linkedin    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  key   String @id
  value String
}
